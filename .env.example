# lofivid environment — copy to .env and fill in.
# .env is gitignored; .env.example is the template.

# ---- Music: Suno (cloud, optional) ----------------------------------------
# Only required when a style sets `music_backend: suno`. The morning_cafe
# style uses the LOCAL library backend, so you can leave these empty unless
# you want vocals via Suno.
#
# Suno has no official public API; you talk to a third-party wrapper:
#   sunoapi.org   — default; needs your own Suno session cookie or wrapper API key
#   PiAPI         — multi-vendor aggregator
#   AIML API      — multi-vendor aggregator
#
# Verify the wrapper's ToS AND your Suno subscription tier permits commercial
# use before publishing. Fully-AI music is not US-copyrightable.
SUNO_API_KEY=
SUNO_API_BASE=https://api.sunoapi.org

# ---- Visuals: Unsplash (cloud, optional) ----------------------------------
# Required when a style sets `keyframe_backend: unsplash` (the morning_cafe
# style does). Free tier = 50 requests/hour on demo apps; apply for production
# access if you'll render frequently. The backend writes a per-photo
# attribution sidecar — include those credits in your video description.
# Register at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ---- Music: Pixabay (cloud, library ingest) -------------------------------
# Required when running `lofivid music-ingest --source pixabay`.
#
# Pixabay Music's catalogue is licensed under the Pixabay Content License,
# which is CC0-equivalent for commercial use — no attribution required, and
# monetisation (incl. YouTube AdSense) is explicitly allowed. The ingest
# layer still writes the track's `original_url` into the per-track sidecar
# so you can audit the licence trail later.
#
# Sign up for a free key at https://pixabay.com/accounts/register/
# Free tier = 100 requests / 60 seconds, plenty for library ingest.
#
# Endpoint default: https://pixabay.com/api/music. If the music API moves,
# override via PIXABAY_API_BASE without touching code.
PIXABAY_API_KEY=
# PIXABAY_API_BASE=https://pixabay.com/api/music

# ---- Music: Content ID claims (read this before publishing) ---------------
# Pixabay's license permits commercial monetised use, but some uploaders
# also register their tracks with YouTube's Content ID. Even properly
# licensed use can trigger automated claims (not copyright strikes — claims
# just redirect monetisation to the claimant until you dispute).
#
# The pipeline surfaces this risk per track in run_manifest.json:
#   music_attributions[i].at_risk_for_content_id_claim
#     true   = Pixabay track without a license certificate URL
#     false  = manual / Pixabay-with-certificate / FMA / etc.
#     null   = no sidecar (unknown)
#
# Dispute workflow if YouTube fires an automated claim:
#   YouTube Studio → Content → "See Details" → Dispute →
#     "I have permission or a license to use the content" →
#     paste the track's Pixabay URL + https://pixabay.com/service/license-summary/
#     + the sidecar's license_certificate_url if non-null.
#
# See assets/music/README.md for the full workflow.

# ---- Music: pre-licensed audio (manual ingest) ----------------------------
# For audio you've licensed yourself (your own catalog, CC0 finds, anything
# the `lofivid music-ingest --source manual` command can wrap a sidecar
# around). No env vars needed — the ingest CLI accepts --license,
# --attribution-text, and --license-certificate-url directly.

# ---- Hugging Face (model weights) ----------------------------------------
# Needed for any gated model: Animagine XL 4 (anime preset), some FLUX.2
# variants, possibly Z-Image-Turbo depending on its mirror. SDXL base 1.0
# and FLUX.2 Klein public mirrors don't require auth, but setting the token
# never hurts and makes downloads more reliable on rate-limited days.
# Get a token at https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=

# Where huggingface_hub caches downloaded weights. Default ~/.cache/huggingface
# is fine; override if you keep model weights on a separate disk.
# HF_HOME=/mnt/models/huggingface

# ---- Pipeline misc -------------------------------------------------------
# Override the repo root used for resolving `style_ref` → styles/<name>.yaml.
# Defaults to the current working directory; only set this if you run lofivid
# from a different directory than the repo root.
# LOFIVID_REPO_ROOT=/home/willy/lofivid
